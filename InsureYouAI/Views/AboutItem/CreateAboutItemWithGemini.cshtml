@{
    ViewData["Title"] = "CreateAboutItemWithGemini";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<!-- Marked.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

@if (ViewBag.value != null)
{
    <div class="article-container" id="articleResult">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 fw-semibold">Oluşturulan Yazı</h5>
                    <div>
                        <button class="btn btn-sm btn-outline-secondary me-2" onclick="copyArticle()">
                            <i class="fas fa-copy"></i> Kopyala
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="downloadArticle()">
                            <i class="fas fa-download"></i> İndir
                        </button>
                    </div>
                </div>

                <!-- Ham markdown gizli tutulur -->
                <div id="rawMarkdown" style="display:none">@ViewBag.Value</div>

                <!-- Render edilmiş içerik buraya gelir -->
                <div class="article-content" id="articleContent"></div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const rawEl = document.getElementById("rawMarkdown");
        const contentEl = document.getElementById("articleContent");

        if (rawEl && contentEl) {
            marked.setOptions({
                breaks: true,       // \n → <br>
                gfm: true           // GitHub Flavored Markdown
            });

            contentEl.innerHTML = marked.parse(rawEl.innerText);
        }
    });

    function copyArticle() {
        const content = document.getElementById("articleContent").innerText;
        navigator.clipboard.writeText(content).then(function () {
            alert("Metin kopyalandı!");
        }).catch(function () {
            alert("Kopyalama başarısız.");
        });
    }

    function downloadArticle() {
        const content = document.getElementById("articleContent").innerText;
        const blob = new Blob([content], { type: "text/plain;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "olusturulan-yazi.txt";
        a.click();
        URL.revokeObjectURL(url);
    }
</script>