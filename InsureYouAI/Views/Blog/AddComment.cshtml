<div id="comments" class="comments-area  mt-45">
    <div id="respond" class="comment-respond">
        <h3 id="reply-title" class="comment-reply-title">Yorum Bırak <small><a rel="nofollow" id="cancel-comment-reply-link" href="/finco/?p=2112#respond" style="display:none;">Cancel reply</a></small></h3>
        <form asp-controller="Blog" asp-action="AddComment" method="post" id="commentform" class="comment-form" novalidate="">
            <p class="comment-form-comment"><label for="comment">Yorum</label> 
                <input type="hidden" name="ArticleId" value="@ViewBag.ArticleId" />
                <textarea id="comment" name="CommentDetail" cols="45" rows="8" maxlength="65525" required="required"></textarea></p>
            <p class="form-submit">
                <input name="submit" type="submit" id="submit" class="submit" value="Yorum Oluştur">
            </p>
        </form>
    </div>
    <!-- #respond -->
</div>
