<div class="row row-cols-1 row-cols-lg-4 row-cols-xl-4">
    <div class="col">
        <div class="card rounded-4 bg-purple">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.TotalCategoryCount</h4>
                        <p class="mb-1 text-white">Toplam Kategori Sayısı</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-hand-thumbs-up-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card rounded-4 bg-primary">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.TotalArticleCount</h4>
                        <p class="mb-1 text-white">Toplam Makale Sayısı </p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-chat-left-text-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card rounded-4 bg-orange">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.TotalPoliciesCount</h4>
                        <p class="mb-1 text-white">Satılan Poliçe Sayısı</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-share-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card rounded-4 bg-success">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.TotalPoliciesByThisMonthCount</h4>
                        <p class="mb-1 text-white">Bu Ay Satılan Poliçe Sayısı</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-browser-edge"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div><!--end row-->
<div class="row row-cols-1 row-cols-lg-4 row-cols-xl-4">
    <div class="col">
        <div class="card rounded-4 bg-warning">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.TotalCommentsCount</h4>
                        <p class="mb-1 text-white">Toplam Yorum Sayısı</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-chat-dots-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card rounded-4 bg-danger">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.TotalUserCount</h4>
                        <p class="mb-1 text-white">Toplam Kullanıcı Sayısı</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card rounded-4 bg-pink">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.AvgPolicyAmount.ToString("0.00") ₺</h4>
                        <p class="mb-1 text-white">Ortalama Poliçe Ücreti</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-graph-up"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card rounded-4 bg-info">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="">
                        <h4 class="mb-0 text-white">@ViewBag.LatestRevenueAmount.ToString("0.00") ₺</h4>
                        <p class="mb-1 text-white">Son Poliçe Ücreti</p>
                    </div>
                    <div class="ms-auto fs-3 text-white">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div><!--end row-->
