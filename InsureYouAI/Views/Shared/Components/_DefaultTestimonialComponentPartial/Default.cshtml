@model List<Testimonial>
<section id="testimonial" class="testimonial-area pt-120 pb-30 p-relative fix" style="background-color: #28314b;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title center-align mb-50 text-center" data-aos="fade-up" data-aos-duration="1000">
                    <h2 style="color:white!important">Müşterilerimiz Bizim İçin Ne Dediler ?</h2>
                </div>
            </div>
            <div class="col-lg-12">
                <div class="testimonial-active" data-aos="fade-up" data-aos-duration="1400">
                    @foreach (var item in Model)
                    {
                        <div class="single-testimonial">
                            <p>"@item.CommentDetail".</p>
                            <div class="qt-img">
                                <img src="/defaultimages/qt-icon.png" alt="img">
                            </div>
                            <div class="testi-author">
                                <div class="author-img-wrapper">
                                    <img src="@item.ImageUrl" alt="img">
                                </div>
                                <div class="ta-info">
                                    <h6>@item.NameSurname</h6>
                                    <span>@item.Title</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="row align-items-center">
            <div class="col-md-12 text-center">
                <div class="text-bg" data-aos="fade-up" data-aos-duration="1000">
                    <h2>Geri Dönüşler</h2>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .testi-author {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-top: 20px;
    }

    .author-img-wrapper {
        flex-shrink: 0;
    }

        .author-img-wrapper img {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

    .ta-info h6 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
        color: #fff;
    }

    .ta-info span {
        font-size: 14px;
        color: #a8b3c7;
    }

    .single-testimonial {
        
        padding: 30px;
        border-radius: 10px;
        margin: 0 15px;
        transition: transform 0.3s ease;
    }

        .single-testimonial:hover {
            transform: translateY(-5px);
        }

        .single-testimonial p {
            color: black;
            font-size: 16px;
            line-height: 1.8;
            font-style: italic;
            margin-bottom: 20px;
        }
</style>