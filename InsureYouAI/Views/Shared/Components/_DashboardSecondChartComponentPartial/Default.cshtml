@model List<AiAnalysisChartViewModel>

<div class="col-12 col-lg-4 col-xl-4 d-flex">
    <div class="card w-100 rounded-4">
        <div class="card-body">
            <div class="d-flex align-items-center mb-3">
                <h6 class="mb-0">En Çok Tercih Edilen İlk 3 Poliçe Türü Analizi</h6>
            </div>
            <div class="d-flex justify-content-center">
                @{
                    var ringColors = new[] { "#7c3aed", "#f97316", "#22d3ee" };
                    var total = Model.Sum(x => x.Value);
                    var cx = 100; var cy = 100;
                    var radii = new[] { 80, 62, 44 };
                    var strokeWidth = 12;
                }
                <svg width="340" height="340" viewBox="0 0 200 200">
                    @for (int i = 0; i < Model.Count && i < 3; i++)
                    {
                        var r = radii[i];
                        var circumference = 2 * Math.PI * r;
                        var pct = total > 0 ? (double)Model[i].Value / total : 0;
                        var dash = pct * circumference;
                        var gap = circumference - dash;
                        <circle cx="@cx" cy="@cy" r="@r"
                                fill="none"
                                stroke="#e5e7eb"
                                stroke-width="@strokeWidth" />
                        <circle cx="@cx" cy="@cy" r="@r"
                                fill="none"
                                stroke="@ringColors[i]"
                                stroke-width="@strokeWidth"
                                stroke-dasharray="@dash.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) @gap.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                stroke-dashoffset="@(circumference * 0.25).ToString(" F2", System.Globalization.CultureInfo.InvariantCulture)"
                                stroke-linecap="round"
                                transform="rotate(-90 @cx @cy)" />
                    }
                    <text x="@cx" y="@(cy - 8)" text-anchor="middle" font-size="11" fill="#6b7280">Total</text>
                    <text x="@cx" y="@(cy + 14)" text-anchor="middle" font-size="26" font-weight="bold" fill="#111827">@total</text>
                </svg>
            </div>
        </div>
        <ul class="list-group list-group-flush mb-0 shadow-none">
            @for (int i = 0; i < Model.Count; i++)
            {
                <li class="list-group-item bg-transparent @(i == 0 ? "border-top" : "") py-3">
                    <span class="me-2" style="color:@ringColors[i]; font-size:14px;">●</span>
                    <span style="font-size:15px;">@Model[i].Name</span>
                    <span class="float-end fw-semibold" style="font-size:15px;">@Model[i].Value</span>
                </li>
            }
        </ul>
    </div>
</div>