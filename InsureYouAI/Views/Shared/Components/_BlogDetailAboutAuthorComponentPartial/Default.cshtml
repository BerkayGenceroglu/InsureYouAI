@model Article
<div style="width: 100%; padding: 48px 24px 56px; text-align: center; box-sizing: border-box; border-top: 0.5px solid rgba(0,0,0,0.12); border-bottom: 0.5px solid rgba(0,0,0,0.12);">

    <div style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; margin: 0 auto 20px; border: 3px solid rgba(0,0,0,0.15);">
        <img src="@Model.AppUser.ImageUrl"
             alt="@Model.AppUser.Name @Model.AppUser.Surname"
             style="width: 100%; height: 100%; object-fit: cover; display: block;">
    </div>

    <h5 style="font-size: 1.15rem; font-weight: 600; margin: 0 0 12px; letter-spacing: 0.01em;">
       Yazar : @Model.AppUser.Name @Model.AppUser.Surname
    </h5>

    <div style="width: 40px; height: 2px; background: rgba(0,0,0,0.15); margin: 0 auto 14px; border-radius: 2px;"></div>

    <div style="display: flex; justify-content: center; align-items: center; gap: 10px; margin-bottom: 24px;">
        <a href="#" style="width:34px; height:34px; border-radius:50%; border:1px solid rgba(0,0,0,0.15); display:flex; align-items:center; justify-content:center; color:inherit; text-decoration:none;">
            <i class="fab fa-facebook-f"></i>
        </a>
        <a href="#" style="width:34px; height:34px; border-radius:50%; border:1px solid rgba(0,0,0,0.15); display:flex; align-items:center; justify-content:center; color:inherit; text-decoration:none;">
            <i class="fab fa-twitter"></i>
        </a>
        <a href="#" style="width:34px; height:34px; border-radius:50%; border:1px solid rgba(0,0,0,0.15); display:flex; align-items:center; justify-content:center; color:inherit; text-decoration:none;">
            <i class="fab fa-instagram"></i>
        </a>
        <a href="#" style="width:34px; height:34px; border-radius:50%; border:1px solid rgba(0,0,0,0.15); display:flex; align-items:center; justify-content:center; color:inherit; text-decoration:none;">
            <i class="fab fa-behance"></i>
        </a>
        <a href="#" style="width:34px; height:34px; border-radius:50%; border:1px solid rgba(0,0,0,0.15); display:flex; align-items:center; justify-content:center; color:inherit; text-decoration:none;">
            <i class="fab fa-linkedin"></i>
        </a>
    </div>

    <p style="font-size: 14px; line-height: 1.8; color: #666; max-width: 520px; margin: 0 auto;">
        @Model.AppUser.Description
    </p>

</div>