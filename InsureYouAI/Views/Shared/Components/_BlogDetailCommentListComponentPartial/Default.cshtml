@model List<Comment>
<div style="width: 100%; padding: 40px 24px 48px; box-sizing: border-box; border-top: 0.5px solid rgba(0,0,0,0.1);">

    <h5 style="font-size: 1rem; font-weight: 600; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 0.5px solid rgba(0,0,0,0.1);">
        Yorumlar (@Model.Count)
    </h5>

    @foreach (var item in Model)
    {
        <div style="display: flex; gap: 16px; align-items: flex-start; padding: 20px 0; border-bottom: 0.5px solid rgba(0,0,0,0.08);">

            <div style="width: 60px; height: 60px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 1px solid rgba(0,0,0,0.1);">
                <img src="@item.AppUser.ImageUrl" alt="@item.AppUser.Name"
                     style="width: 100%; height: 100%; object-fit: cover; display: block;">
            </div>

            <div style="flex: 1; min-width: 0;">
                <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 6px; margin-bottom: 8px;">
                    <span style="font-size: 14px; font-weight: 600; color: inherit;">
                        @item.AppUser.Name @item.AppUser.Surname
                    </span>
                    <span style="font-size: 12px; color: #999;">
                        @item.CommentDate.ToString("dd MMMM yyyy")
                    </span>
                </div>
                <p style="font-size: 14px; line-height: 1.75; color: #666; margin: 0; word-break: break-word;">
                    @item.CommentDetail
                </p>
            </div>

        </div>
    }

</div>