@model List<PolicyForecastViewModel>

@{
    var totalForecast = Model.Sum(x => x.ForecastCount);
}

@functions {
    string GetEmoji(string policyType)
    {
        return policyType switch
        {
            "Egitim" => "🎓",
            "Kasko" => "🚗",
            "Konut" => "🏠",
            "Saglik" => "🩺",
            "Trafik" => "🚦",
            _ => "📄"
        };
    }
}

<div class="col-12 col-lg-6 col-xl-6 d-flex">
    <div class="card rounded-4 w-100">
        <div class="card-body">

            <div class="d-flex align-items-center mb-3">
                <div>
                    <h6 class="mb-0">Gelecek Ay Tahmini Poliçe Dağılımı</h6>
                    <small class="text-muted">ML.NET SSA Forecasting</small>
                </div>
            </div>

            <div class="mt-4">

                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="d-flex align-items-start gap-3">

                            <div class="product-box border d-flex justify-content-center align-items-center"
                                 style="width:45px;height:45px;border-radius:10px;font-size:24px;background:#f8f9fa;">
                                @GetEmoji(item.PolicyType)
                            </div>

                            <div class="flex-grow-1">

                                <p class="my-2">
                                    <span class="fw-bold">@item.PolicyType</span>

                                    <span class="float-end">
                                        <span class="text-primary">@item.ForecastCount Adet</span>
                                        <span class="ms-3 fw-bold text-dark">
                                            @item.Percentage
                                            %
                                        </span>
                                    </span>
                                </p>

                                <div class="progress" style="height:6px;">
                                    <div class="progress-bar bg-primary"
                                         style="width:@item.Percentage%">
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (item != Model.Last())
                        {
                            <hr class="my-3" />
                        }
                    }
                }
            </div>

            @if (totalForecast > 0)
            {
                <div class="mt-3 pt-3 border-top text-center">
                    <small class="text-muted">
                        Önümüzdeki ay toplam <strong>@totalForecast</strong> poliçe beklenmektedir.
                    </small>
                </div>
            }

        </div>
    </div>
</div>