@{
    Layout = null;
}
<!doctype html>
<html class="no-js" lang="zxx">
@await Component.InvokeAsync("_DefaultHeadComponentPartial")
<body>
    <!-- header -->
    <header class="header-area header-three">
        @await Component.InvokeAsync("_DefaultHeaderComponentPartial")
        @await Component.InvokeAsync("_DefaultHeaderContactComponentPartial")
        @await Component.InvokeAsync("_DefaultNavbarComponentPartial")
    </header>
    <!-- header-end -->
    <!-- offcanvas-area -->
        @await Component.InvokeAsync("_DefaultMobileMenuComponentPartial")
    <!-- offcanvas-end -->
    <!-- main-area -->
    <main>
        <!-- slider-area -->
        @await Component.InvokeAsync("_DefaultSliderComponentPartial")
        <!-- slider-area-end -->
        <!-- about-area -->
        @await Component.InvokeAsync("_DefaultAboutComponentPartial")
        <!-- about-area-end -->
        <!-- service-area -->
        @await Component.InvokeAsync("_DefaultInsureServiceComponentPartial")
        <!-- service-details2-area-end -->
        <!-- video-area -->
        @await Component.InvokeAsync("_DefaultTrailerVideoComponentPartial")
        <!-- video-area-end -->
        <!-- services-five-area -->
        @await Component.InvokeAsync("_DefaultServiceComponentPartial")
        <!-- services-three-area -->
        <!-- counter-area -->
        @await Component.InvokeAsync("_DefaultCounterComponentPartial")
        <!-- counter-area-end -->
        <!-- skill-area -->
        @await Component.InvokeAsync("_DefaultSkillComponentPartial")
        <!-- skill-area-end -->
        <!-- pricing-area -->
        @await Component.InvokeAsync("_DefaultPricingPlanComponentPartial")
        <!-- pricing-area-end -->
        <!-- testimonial-area -->
        @await Component.InvokeAsync("_DefaultTestimonialComponentPartial")
        <!-- testimonial-area-end -->
        <!-- gallery-area -->
        @await Component.InvokeAsync("_DefaultGalleryComponentPartial")
        <!-- gallery-area-end -->
        <!-- blog-area -->
        @await Component.InvokeAsync("_DefaultLast3BlogsComponentPartial")
        <!-- blog-area-end -->
        <!-- contact-area -->
        @await Html.PartialAsync("~/Views/Default/SendMessage.cshtml")
        <!-- contact-area-end -->
        <!-- newslater-area -->
        @await Html.PartialAsync("~/Views/Default/SubscribeMessage.cshtml")
        <!-- newslater-aread-end -->
    </main>
    <!-- main-area-end -->
    <!-- footer -->
    @await Component.InvokeAsync("_DefaultFooterComponentPartial")
    <!-- footer-end -->
    <!-- JS here -->
    @await Component.InvokeAsync("_DefaultScriptComponentPartial")
</body>
</html>