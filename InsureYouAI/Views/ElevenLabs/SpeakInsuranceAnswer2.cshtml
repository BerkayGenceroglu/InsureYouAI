@{
    ViewData["Title"] = "InsureYOU AI Voice";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --brand-color: #3A9AFF;
        --brand-hover: #2d81d6;
    }

    .ai-voice-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e0e6ed;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .card-header-custom {
        background-color: var(--brand-color);
        color: white;
        padding: 25px;
        text-align: center;
    }

    .studio-panel {
        padding: 30px;
    }

    .form-control-custom {
        border: 2px solid #f0f2f5;
        border-radius: 12px;
        padding: 15px;
        transition: all 0.2s;
        background-color: #fcfcfd;
    }

        .form-control-custom:focus {
            border-color: var(--brand-color);
            box-shadow: 0 0 0 4px rgba(58, 154, 255, 0.1);
            background-color: #fff;
            outline: none;
        }

    .btn-brand {
        background-color: var(--brand-color);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 25px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-brand:hover {
            background-color: var(--brand-hover);
            color: white;
            transform: translateY(-1px);
        }

    /* Avatar ve Oynatma Alanı */
    .avatar-container {
        background: #f8fafc;
        border-radius: 20px;
        padding: 40px;
        margin-top: 20px;
        border: 1px dashed #cbd5e1;
        position: relative;
    }

    .avatar-wrapper {
        width: 150px;
        height: 150px;
        margin: 0 auto 20px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        border: 3px solid var(--brand-color);
        overflow: hidden;
    }

    #aiAvatar {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .pulse-animation {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(58, 154, 255, 0.4);
        }

        70% {
            box-shadow: 0 0 0 15px rgba(58, 154, 255, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(58, 154, 255, 0);
        }
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="ai-voice-card">
                <div class="card-header-custom">
                    <h4 class="fw-bold mb-0">Metinlerinizi Yapay Zeka İle Seslendirin</h4>
                    <p class="small opacity-75 mb-0">İlgili metni girerek yapay zekayı sesli olarak çalıştırabilirsiniz.</p>
                </div>

                <div class="studio-panel">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Seslendirilecek Metin</label>
                            <textarea name="text" id="text" class="form-control form-control-custom" rows="4"
                                      placeholder="Merhaba, bugün size nasıl yardımcı olabilirim?"></textarea>
                        </div>

                        <button type="submit" class="btn btn-brand w-100">
                           Sesi ve Karakteri Hazırla
                        </button>
                    </form>

                    @if (ViewBag.AudioUrl != null)
                    {
                        <div class="avatar-container text-center mt-4">
                            <div class="avatar-wrapper" id="avatarBox">
                                <img id="aiAvatar" src="/aitalk.gif" style="display:none;" />
                                <i id="staticIcon" class="bi bi-person-fill text-muted" style="font-size: 4rem;"></i>
                            </div>

                            <h5 class="fw-bold text-dark mb-3">AI Asistanınız Hazır</h5>

                            <button id="playBtn" class="btn btn-brand rounded-pill px-5">
                                <i class="bi bi-play-fill me-1"></i> Oynat
                            </button>

                            <audio id="voiceAudio">
                                <source src="@ViewBag.AudioUrl" type="audio/mpeg" />
                            </audio>
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3 border-0 small">
                            <i class="bi bi-exclamation-circle me-2"></i> @ViewBag.Error
                        </div>
                    }
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">InsureYOU Yapay Zeka Laboratuvarı &copy; 2026</p>
            </div>

        </div>
    </div>
</div>

<script>
    var audio = document.getElementById("voiceAudio");
    var btn = document.getElementById("playBtn");
    var avatar = document.getElementById("aiAvatar");
    var staticIcon = document.getElementById("staticIcon");
    var avatarBox = document.getElementById("avatarBox");

    if (audio && btn) {
        btn.addEventListener("click", function () {
            if (audio.paused) {
                audio.play();
                // Oynarken
                avatar.style.display = "block";
                if(staticIcon) staticIcon.style.display = "none";
                avatarBox.classList.add("pulse-animation");
                btn.innerHTML = '<i class="bi bi-pause-fill me-1"></i> Durdur';
                btn.classList.replace("btn-brand", "btn-dark");
            } else {
                pauseVoice();
            }
        });

        audio.onended = function () {
            pauseVoice();
        };

        function pauseVoice() {
            audio.pause();
            avatar.style.display = "none";
            if(staticIcon) staticIcon.style.display = "block";
            avatarBox.classList.remove("pulse-animation");
            btn.innerHTML = '<i class="bi bi-play-fill me-1"></i> Oynat';
            btn.classList.replace("btn-dark", "btn-brand");
        }
    }
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">