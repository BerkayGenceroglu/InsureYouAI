@model List<Comment>

@{
    ViewData["Title"] = "CommentList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">

        <div class="d-flex align-items-center mb-3">
            <h4 class="fw-bold mb-0 text-primary">
                Sigorta Makale Yorumları
            </h4>

            <form class="ms-auto position-relative" style="max-width:260px;">
                <div class="position-absolute top-50 translate-middle-y px-3">
                    <i class="bi bi-search text-secondary"></i>
                </div>
                <input class="form-control ps-5 rounded-pill shadow-sm"
                       type="text"
                       placeholder="Yorum ara...">
            </form>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="text-muted">#</th>
                        <th class="text-muted">Ad Soyad</th>
                        <th class="text-muted">Makale</th>
                        <th class="text-muted">Tarih</th>
                        <th class="text-muted">Analiz / Durum</th>
                        <th class="text-center text-muted">Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted italic">
                                <i class="bi bi-chat-left-text me-1"></i> Henüz bir yorum bulunamadı.
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        count++;
                        /* Toksiklik Kontrolü:
                        Burada CommentStatus == "Toxic" veya IsToxic == true gibi bir mantık kullanabilirsin.
                        Aşağıdaki örnekte Status üzerinden gidilmiştir. */
                        bool isToxic = item.CommentStatus == "Toksik Yorum"; // Kendi veritabanı alanına göre güncelle

                        <tr class="@(isToxic ? "toxic-row" : "safe-row") table-row-hover">
                            <td>
                                <span class="badge @(isToxic ? "bg-danger" : "bg-success") bg-opacity-75">@count</span>
                            </td>

                            <td class="fw-semibold">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm me-2 rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:30px; height:30px;">
                                        <i class="bi bi-person text-secondary"></i>
                                    </div>
                                    @item.AppUser.Name @item.AppUser.Surname
                                </div>
                            </td>

                            <td class="small text-muted">
                                @(item.Article.Title.Length > 30 ? item.Article.Title.Substring(0, 30) + "..." : item.Article.Title)
                            </td>

                            <td>
                                <span class="small">@item.CommentDate.ToString("dd.MM.yyyy")</span>
                            </td>

                            <td>
                                @if (isToxic)
                                {
                                    <span class="badge bg-danger rounded-pill px-3">
                                        <i class="bi bi-exclamation-octagon me-1"></i> Toksik Tespit Edildi
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill px-3">
                                        <i class="bi bi-check-circle me-1"></i> Güvenli
                                    </span>
                                }
                            </td>

                            <td class="text-center">
                                <a href="/Comment/DeleteComment/@item.CommentId"
                                   class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm"
                                   data-bs-toggle="tooltip" title="Sil">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Toksik Satır Stili: Hafif kırmızı transparan arka plan */
    .toxic-row {
        background-color: rgba(220, 53, 69, 0.08) !important;
    }

    /* Güvenli Satır Stili: Hafif yeşil transparan arka plan */
    .safe-row {
        background-color: rgba(25, 135, 84, 0.05) !important;
    }

    .table-row-hover:hover {
        background-color: rgba(0, 0, 0, 0.03) !important;
        transition: .2s;
    }

    .badge {
        font-weight: 500;
    }
</style>

<script>
    // Tooltip'leri aktif et
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl)
    })
</script>