@model AIInsuranceRecommendationViewModel

@{
    ViewData["Title"] = "CreateUserCustomizePlan";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    /* Özel Stil İyileştirmeleri */
    .insurance-card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s ease;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px 15px;
        border: 1px solid #e0e6ed;
    }

        .form-control:focus, .form-select:focus {
            border-color: #4a7cff;
            box-shadow: 0 0 0 0.2rem rgba(74, 124, 255, 0.1);
        }

    .btn-ai-submit {
        background: linear-gradient(135deg, #4a7cff 0%, #00d2ff 100%);
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: transform 0.2s;
    }

        .btn-ai-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(74, 124, 255, 0.3);
        }

    .ai-result-header {
        background: linear-gradient(to right, #f8faff, #ffffff);
        border-left: 5px solid #4a7cff;
    }
</style>

<section class="pt-5 pb-5 bg-light min-vh-100">
    <div class="container">
        <div class="row align-items-start">
            <div class="col-lg-7">
                <div class="card insurance-card shadow-sm p-4 p-md-5 bg-white">
                    <div class="mb-4">
                        <h2 class="fw-bold text-dark">Kişiye Özel Sigorta Planı</h2>
                        <p class="text-muted">Bilgilerinizi girerek yapay zeka destekli en uygun teklifleri anında görüntüleyin.</p>
                    </div>

                    <form asp-action="CreateUserCustomizePlan" asp-controller="PricingPlan" method="post" id="aiPlanForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Yaş</label>
                                <input asp-for="Age" class="form-control" type="number" min="18" placeholder="Örn: 28" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Şehir</label>
                                <input asp-for="City" class="form-control" placeholder="İstanbul..." />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Meslek</label>
                                <input asp-for="Occupation" class="form-control" placeholder="Yazılım, Eğitim vb." />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Medeni Durum</label>
                                <select asp-for="MaritalStatus" class="form-select">
                                    <option value="">Seçiniz</option>
                                    <option>Bekar</option>
                                    <option>Evli</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Çocuk Sayısı</label>
                                <input asp-for="ChildrenCount" class="form-control" type="number" min="0" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Seyahat Sıklığı</label>
                                <select asp-for="TravelFrequency" class="form-select">
                                    <option value="">Seçiniz</option>
                                    <option>Yılda 1-2 kez</option>
                                    <option>Yılda 3-5 kez</option>
                                    <option>Sık seyahat ediyorum</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Aylık Maksimum Bütçe</label>
                                <div class="input-group">
                                    <input asp-for="MonthlyBudget" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                    <span class="input-group-text bg-light">₺</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-uppercase">Teminat Önceliği</label>
                                <select asp-for="CoveragePriority" class="form-select">
                                    <option value="">Seçiniz</option>
                                    <option>Sağlık</option>
                                    <option>Araç</option>
                                    <option>Seyahat</option>
                                    <option>Genel Koruma</option>
                                </select>
                            </div>

                            <div class="col-12 my-3">
                                <div class="form-check form-switch">
                                    <input asp-for="HasChronicDisease" class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" />
                                    <label class="form-check-label fw-medium" for="flexSwitchCheckDefault">Kronik bir hastalığım var</label>
                                </div>
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label fw-semibold small text-uppercase">Hastalık Detayı <span class="text-muted text-lowercase font-italic">(isteğe bağlı)</span></label>
                                <textarea asp-for="ChronicDiseaseDetails" class="form-control" rows="2" placeholder="Diyabet, tansiyon vb."></textarea>
                            </div>

                            <div class="col-12 pt-2">
                                <button type="submit" class="btn btn-ai-submit btn-primary w-100 py-3 text-white">
                                     Planımı Analiz Et ve Öner
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-5">
                @if (!string.IsNullOrEmpty(Model.RecommendedPackage))
                {
                    <div class="card insurance-card shadow border-0 overflow-hidden bg-white">
                        <div class="bg-primary p-3 text-center">
                            <span class="text-white small fw-bold text-uppercase tracking-wider">AI Önerisi Hazır</span>
                        </div>
                        <div class="card-body p-4">
                            <div class="ai-result-header p-3 mb-4 rounded-3">
                                <h6 class="text-primary mb-1 fw-bold">Önerilen Ana Paket</h6>
                                <h3 class="fw-bold mb-0 text-dark">@Model.RecommendedPackage</h3>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold d-flex align-items-center">
                                    <span class="me-2 text-primary">●</span> Neden Bu Paket?
                                </h6>
                                <p class="text-muted ps-3 mb-0" style="line-height: 1.6;">
                                    @Model.AnalysisText
                                </p>
                            </div>

                            <hr class="text-light" />

                            <div class="p-3 rounded-3" style="background-color: #fff9e6; border: 1px dashed #ffca2c;">
                                <h6 class="fw-bold text-warning-emphasis mb-1">Alternatif Seçenek</h6>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-dark">@Model.SecondBestPackage</span>
                                    <span class="badge bg-warning text-dark rounded-pill">Ekonomik</span>
                                </div>
                            </div>

                            <button class="btn btn-outline-primary w-100 mt-4 rounded-pill fw-bold">
                                Detayları İncele
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card insurance-card border-0 shadow-sm bg-white text-center p-5">
                        <div class="mb-4">
                            <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="bi bi-stars text-primary fs-1"></i>
                            </div>
                        </div>
                        <h5 class="fw-bold">Sonuçlar Bekleniyor</h5>
                        <p class="text-muted px-md-4">
                            Formu eksiksiz doldurduğunuzda, yapay zekamız binlerce senaryoyu tarayarak size en uygun maliyetli sigorta planını burada sunacaktır.
                        </p>
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <span class="spinner-grow spinner-grow-sm text-primary opacity-25"></span>
                            <span class="spinner-grow spinner-grow-sm text-primary opacity-50"></span>
                            <span class="spinner-grow spinner-grow-sm text-primary"></span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>