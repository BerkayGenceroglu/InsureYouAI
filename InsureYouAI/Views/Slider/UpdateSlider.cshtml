@model Slider

@{
    ViewData["Title"] = "UpdateSlider";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}




<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Slider Düzenleme</h5>
            <form class="ms-auto position-relative">
                <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-search"></i></div>
                <input class="form-control ps-5" type="text" placeholder="search">
            </form>
        </div>
        <br />
        <form method="post">
            <input type="hidden" asp-for="SliderId" />
            <label>Başlık</label>
            <input class="form-control" asp-for=Title />
            <br />
            <label>Görsel</label>
            <input class="form-control" asp-for=ImageUrl />
            <br />
            <label>Açıklama</label>
            <textarea class="form-control" asp-for=Description rows="5"></textarea>
            <br />
            <button type="submit" class="btn btn-primary">Slider Güncelle</button>
        </form>
    </div>
</div>








